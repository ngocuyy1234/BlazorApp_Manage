@page "/servers"
@using BlazorApp_Manage.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]
@inject IDbContextFactory<WebAppManageContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JsRuntime

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-primary"><i class="bi bi-server-stack-nav-menu"></i> Quản lý Máy chủ & Ảo hóa</h3>
            <p class="text-muted small mb-0">Quản lý hệ thống Server vật lý (Host) và các Máy ảo (VM) bên trong.</p>
        </div>

        <AuthorizeView Roles="Admin,Technician">
            <Authorized>
                <button class="btn btn-primary shadow-sm px-4" @onclick="() => OpenModal()">
                    <i class="bi bi-plus-circle-fill"></i> Thêm Máy chủ / VM
                </button>
            </Authorized>
        </AuthorizeView>
    </div>

    @if (physicalServers == null)
    {
        <div class="text-center py-5"><div class="spinner-border text-primary"></div></div>
    }
    else
    {
        <div class="card shadow-sm border-0 rounded-3 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th>Tên Server / Máy ảo</th>
                            <th>Phân loại</th>
                            <th>Vị trí (Tòa - Phòng - Rack)</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* IN DANH SÁCH MÁY CHỦ VẬT LÝ TRƯỚC *@
                        @foreach (var host in physicalServers)
                        {
                            <tr class="table-light border-bottom border-primary border-opacity-25">
                                <td>
                                    <span class="fw-bold text-dark"><i class="bi bi-hdd-rack-fill text-primary me-2"></i>@host.DeviceName</span><br />
                                    <small class="text-muted ms-4">SN: @(string.IsNullOrEmpty(host.SerialNumber) ? "N/A" : host.SerialNumber)</small>

                                    @* --- BỔ SUNG: THANH DUNG LƯỢNG RAM TÍNH TOÁN TỰ ĐỘNG --- *@
                                    @if (host.RamGb > 0)
                                    {
                                        var childVmsForCap = virtualMachines.Where(v => v.ParentDeviceId == host.DeviceId).ToList();
                                        var usedRam = childVmsForCap.Sum(v => v.RamGb ?? 0);
                                        var ramPercent = Math.Round((double)usedRam / host.RamGb.Value * 100, 1);
                                        var barColor = ramPercent > 85 ? "bg-danger" : (ramPercent > 60 ? "bg-warning" : "bg-success");

                                        <div class="mt-2 ms-4" style="max-width: 250px;">
                                            <div class="d-flex justify-content-between small mb-1">
                                                <span class="text-muted fw-bold" style="font-size: 0.75rem;">RAM: @usedRam / @host.RamGb GB</span>
                                                <span class="text-muted" style="font-size: 0.75rem;">@ramPercent%</span>
                                            </div>
                                            <div class="progress" style="height: 6px;">
                                                <div class="progress-bar @barColor" style="width: @ramPercent%"></div>
                                            </div>
                                        </div>
                                    }
                                    @* -------------------------------------------------------- *@
                                </td>
                                <td><span class="badge bg-primary bg-opacity-75">Server Vật lý</span></td>
                                <td>
                                    <i class="bi bi-geo-alt-fill text-danger small"></i> @host.Location?.Building - @host.Location?.Room
                                    <span class="fw-bold text-primary">@(string.IsNullOrEmpty(host.Location?.Rack) ? "" : $"({host.Location.Rack})")</span>
                                </td>
                                <td>
                                    <span class="badge @(host.Status == "Online" ? "bg-success" : "bg-secondary")">
                                        @(host.Status == "Online" ? "● Online" : "○ Offline")
                                    </span>
                                </td>
                                <td class="text-center">
                                    <AuthorizeView Roles="Admin,Technician">
                                        <Authorized>
                                            <div class="btn-group shadow-sm">
                                                <button class="btn btn-sm btn-outline-info" title="Bật/Tắt nguồn" @onclick="() => CheckStatus(host)">
                                                    <i class="bi bi-power"></i>
                                                </button>
                                                <button class="btn btn-sm btn-warning ms-1 text-white" title="Chỉnh sửa" @onclick="() => OpenModal(host)">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <button class="btn btn-sm btn-danger ms-1" title="Xóa" @onclick="() => DeleteDevice(host)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                                @* NÚT TẠO NHANH VM CHO HOST NÀY *@
                                                <button class="btn btn-sm btn-success ms-1 text-white" title="Tạo máy ảo (VM) nằm trong Server này" @onclick="() => OpenVmModal(host)">
                                                    <i class="bi bi-boxes"></i> +VM
                                                </button>
                                            </div>
                                        </Authorized>
                                    </AuthorizeView>
                                </td>
                            </tr>

                            @* IN DANH SÁCH MÁY ẢO CON NẰM TRONG HOST NÀY *@
                            var childVms = virtualMachines.Where(v => v.ParentDeviceId == host.DeviceId).ToList();
                            foreach (var vm in childVms)
                            {
                                <tr>
                                    <td>
                                        <div class="ms-4">
                                            <span class="text-muted me-1">↳</span>
                                            <i class="bi bi-box text-info me-1"></i>
                                            <span class="fw-medium text-dark">@vm.DeviceName</span><br />
                                            <small class="text-muted ms-4">
                                                MAC: @(string.IsNullOrEmpty(vm.Macaddress) ? "N/A" : vm.Macaddress)
                                                @(vm.RamGb > 0 ? $" | RAM: {vm.RamGb}GB" : "")
                                            </small>
                                        </div>
                                    </td>
                                    <td><span class="badge bg-info text-dark">Máy ảo (VM)</span></td>
                                    <td><span class="text-muted small fst-italic">Chạy trên Host</span></td>
                                    <td>
                                        <span class="badge @(vm.Status == "Online" ? "bg-success" : "bg-secondary")">
                                            @(vm.Status == "Online" ? "● Online" : "○ Offline")
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <AuthorizeView Roles="Admin,Technician">
                                            <Authorized>
                                                <div class="btn-group shadow-sm">
                                                    <button class="btn btn-sm btn-outline-info" title="Bật/Tắt VM" @onclick="() => CheckStatus(vm)">
                                                        <i class="bi bi-power"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-warning ms-1 text-white" title="Chỉnh sửa VM" @onclick="() => OpenModal(vm)">
                                                        <i class="bi bi-pencil-square"></i>
                                                    </button>
                                                    <button class="btn btn-sm btn-danger ms-1" title="Xóa VM" @onclick="() => DeleteDevice(vm)">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </div>
                                            </Authorized>
                                        </AuthorizeView>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }

    @* MODAL THÊM / SỬA MÁY CHỦ & MÁY ẢO *@
    @if (showModal)
    {
        <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(3px);">
            <div class="modal-dialog modal-lg modal-dialog-centered">
                <div class="modal-content border-0 shadow-lg">
                    <div class="modal-header bg-dark text-white">
                        <h5 class="modal-title fw-bold">
                            <i class="bi @(currentDevice.DeviceId == 0 ? "bi-plus-circle" : "bi-pencil-square")"></i>
                            @(currentDevice.DeviceId == 0 ? "Thêm mới Server / VM" : "Chỉnh sửa thông tin")
                        </h5>
                        <button type="button" class="btn-close btn-close-white" @onclick="CloseModal"></button>
                    </div>

                    <div class="modal-body p-4">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">Tên Máy (Hostname) <span class="text-danger">*</span></label>
                                <input class="form-control shadow-sm border-primary" @bind="currentDevice.DeviceName" placeholder="VD: SVR-DB-01" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold text-uppercase small">Loại thiết bị</label>
                                <select class="form-select bg-light" @bind="currentDevice.DeviceTypeId">
                                    @if (deviceTypes != null)
                                    {
                                        @foreach (var type in deviceTypes)
                                        {
                                            <option value="@type.TypeId">@type.TypeName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">Số Serial (SN)</label>
                                <input class="form-control shadow-sm" @bind="currentDevice.SerialNumber" placeholder="Bỏ qua nếu là Máy ảo" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-bold small text-uppercase">Địa chỉ MAC</label>
                                <input class="form-control shadow-sm" @bind="currentDevice.Macaddress" placeholder="Tự sinh nếu để trống" />
                            </div>

                            @* --- BỔ SUNG: CẤU HÌNH PHẦN CỨNG & CẮM CÁP MẠNG --- *@
                            <div class="col-md-12 mt-2">
                                <span class="badge bg-secondary mb-2"><i class="bi bi-cpu"></i> Cấu hình Tài nguyên & Kết nối</span>
                            </div>

                            <div class="col-md-4">
                                <label class="form-label fw-bold small">CPU (Cores)</label>
                                <input type="number" class="form-control shadow-sm" @bind="currentDevice.CpuCores" placeholder="VD: 8" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small">RAM (GB) <span class="text-danger">*</span></label>
                                <input type="number" class="form-control shadow-sm border-warning" @bind="currentDevice.RamGb" placeholder="VD: 16" />
                            </div>
                            <div class="col-md-4">
                                <label class="form-label fw-bold small">Ổ cứng (GB)</label>
                                <input type="number" class="form-control shadow-sm" @bind="currentDevice.StorageGb" placeholder="VD: 500" />
                            </div>

                            @if (currentDevice.IsVirtual != true)
                            {
                                <div class="col-md-6 mt-3">
                                    <label class="form-label fw-bold small text-info"><i class="bi bi-ethernet"></i> Cắm vào Switch nào?</label>
                                    <select class="form-select shadow-sm border-info" @bind="currentDevice.UplinkDeviceId">
                                        <option value="">-- Để trống nếu chưa kết nối --</option>
                                        @if (networkSwitches != null)
                                        {
                                            @foreach (var sw in networkSwitches)
                                            {
                                                <option value="@sw.DeviceId">@sw.DeviceName</option>
                                            }
                                        }
                                    </select>
                                </div>
                                <div class="col-md-6 mt-3">
                                    <label class="form-label fw-bold small text-info">Tại Cổng mạng (Port) số?</label>
                                    <input class="form-control shadow-sm border-info" @bind="currentDevice.UplinkPort" placeholder="VD: Port 05, Gi0/1" />
                                </div>
                            }
                            @* -------------------------------------------------- *@

                            @* --- KHU VỰC THIẾT LẬP ẢO HÓA --- *@
                            <div class="col-md-12 mt-3">
                                <div class="form-check form-switch p-3 bg-light border rounded border-info">
                                    <input class="form-check-input ms-0 me-3" type="checkbox" role="switch" id="switchVirtual" @bind="currentDevice.IsVirtual" style="transform: scale(1.3);">
                                    <label class="form-check-label fw-bold text-primary" for="switchVirtual">Thiết bị này là Máy ảo (Virtual Machine)</label>

                                    @if (currentDevice.IsVirtual == true)
                                    {
                                        <div class="mt-3 pt-3 border-top border-info border-opacity-25">
                                            <label class="form-label fw-bold small text-uppercase text-dark">Nằm trên Máy chủ vật lý (Host) nào? <span class="text-danger">*</span></label>
                                            <select class="form-select border-info" @bind="currentDevice.ParentDeviceId">
                                                <option value="">-- Chọn Server vật lý chứa máy ảo này --</option>
                                                @foreach (var host in physicalServers)
                                                {
                                                    <option value="@host.DeviceId">@host.DeviceName</option>
                                                }
                                            </select>
                                        </div>
                                    }
                                </div>
                            </div>

                            @* --- KHU VỰC NHẬP VỊ TRÍ TỰ DO (Chỉ hiện nếu là Server Vật lý) --- *@
                            @if (currentDevice.IsVirtual != true)
                            {
                                <div class="col-md-12 hr-label mt-4">
                                    <span class="badge bg-secondary mb-2"><i class="bi bi-geo-alt-fill"></i> Vị trí lắp đặt Server tại Data Center</span>
                                </div>

                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Tòa nhà</label>
                                    <input class="form-control" @bind="currentDevice.Location.Building" placeholder="VD: Data Center" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Tầng</label>
                                    <input class="form-control" @bind="currentDevice.Location.Floor" placeholder="VD: Tầng 1" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Phòng</label>
                                    <input class="form-control" @bind="currentDevice.Location.Room" placeholder="VD: Server Room" />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label fw-bold small">Tủ Rack</label>
                                    <input class="form-control" @bind="currentDevice.Location.Rack" placeholder="VD: Rack 42U" />
                                </div>
                            }
                        </div>
                    </div>

                    <div class="modal-footer bg-light">
                        <button class="btn btn-outline-secondary px-4 shadow-sm" @onclick="CloseModal">Hủy bỏ</button>
                        <button class="btn btn-dark px-4 shadow" @onclick="SaveDevice">
                            <i class="bi bi-save"></i> Lưu thông tin
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<Device>? allServers;
    private List<Device> physicalServers = new();
    private List<Device> virtualMachines = new();

    // BỔ SUNG: Chứa danh sách Switch để cắm cáp
    private List<Device> networkSwitches = new();

    private List<DeviceType> deviceTypes = new();
    private Device currentDevice = new();
    private bool showModal = false;

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        using var context = await DbFactory.CreateDbContextAsync();

        // Lọc lấy các thiết bị là Server hoặc Máy ảo
        allServers = await context.Devices
            .Include(d => d.DeviceType)
            .Include(d => d.Location)
            .Where(d => d.IsVirtual == true || (d.DeviceType != null && d.DeviceType.TypeName.Contains("Server")))
            .OrderByDescending(d => d.CreatedDate)
            .ToListAsync();

        physicalServers = allServers.Where(d => d.IsVirtual != true).ToList();
        virtualMachines = allServers.Where(d => d.IsVirtual == true).ToList();

        // BỔ SUNG: Lấy danh sách thiết bị Switch/Router để cắm cáp
        networkSwitches = await context.Devices
            .Include(d => d.DeviceType)
            .Where(d => d.DeviceType != null && (d.DeviceType.TypeName.Contains("Switch") || d.DeviceType.TypeName.Contains("Router")))
            .ToListAsync();

        // Lấy danh sách loại thiết bị để cho vào Dropdown
        var allTypes = await context.DeviceTypes.ToListAsync();
        deviceTypes = allTypes
            .Where(t => !string.IsNullOrWhiteSpace(t.TypeName))
            .GroupBy(t => t.TypeName.Trim().ToLower())
            .Select(g => g.First())
            .ToList();
    }

    private void OpenModal(Device? d = null)
    {
        if (d == null)
        {
            currentDevice = new Device { Status = "Offline", CreatedDate = DateTime.Now, IsVirtual = false };
            currentDevice.Location = new Location();
            if (deviceTypes.Any()) currentDevice.DeviceTypeId = deviceTypes.First().TypeId;
        }
        else
        {
            currentDevice = d;
            if (currentDevice.Location == null) currentDevice.Location = new Location();
        }
        showModal = true;
    }

    // TẠO NHANH MÁY ẢO TỪ MÁY VẬT LÝ
    private void OpenVmModal(Device hostServer)
    {
        currentDevice = new Device
        {
            Status = "Offline",
            CreatedDate = DateTime.Now,
            Location = new Location(),
            IsVirtual = true,
            ParentDeviceId = hostServer.DeviceId
        };
        if (deviceTypes.Any()) currentDevice.DeviceTypeId = deviceTypes.First().TypeId;
        showModal = true;
    }

    private async Task SaveDevice()
    {
        if (string.IsNullOrWhiteSpace(currentDevice.DeviceName))
        {
            await JsRuntime.InvokeVoidAsync("alert", "Vui lòng nhập tên Máy!");
            return;
        }

        try
        {
            using var context = await DbFactory.CreateDbContextAsync();
            bool isNew = currentDevice.DeviceId == 0;

            // --- BỔ SUNG: THUẬT TOÁN CAPACITY PLANNING (KIỂM TRA TRÀN RAM) ---
            if (currentDevice.IsVirtual == true && currentDevice.ParentDeviceId != null)
            {
                var host = await context.Devices.FindAsync(currentDevice.ParentDeviceId);
                if (host != null && host.RamGb > 0)
                {
                    // Tính tổng RAM các máy ảo khác đang chiếm dụng trên con Host này
                    var usedRam = await context.Devices
                        .Where(d => d.ParentDeviceId == host.DeviceId && d.DeviceId != currentDevice.DeviceId)
                        .SumAsync(d => d.RamGb ?? 0);

                    var requestingRam = currentDevice.RamGb ?? 0;
                    var hostTotalRam = host.RamGb.Value;

                    // Nếu Tổng RAM đã dùng + RAM đang xin cấp phép > Tổng RAM thực tế của Host
                    if (usedRam + requestingRam > hostTotalRam)
                    {
                        var freeRam = hostTotalRam - usedRam;
                        await JsRuntime.InvokeVoidAsync("alert", $"⚠ TỪ CHỐI TẠO MÁY ẢO!\n\nHost '{host.DeviceName}' chỉ còn trống {freeRam}GB RAM.\nBạn đang yêu cầu cấp {requestingRam}GB, vượt quá tài nguyên cho phép!");
                        return; // Khóa lệnh lưu, bắt người dùng sửa lại số RAM
                    }
                }
            }
            // -----------------------------------------------------------------

            // XỬ LÝ LOGIC MÁY ẢO
            if (currentDevice.IsVirtual != true)
            {
                currentDevice.ParentDeviceId = null; // Đồ vật lý thì không có Host

                // Thuật toán gán Vị trí tự động cho Máy vật lý
                if (currentDevice.Location != null && !string.IsNullOrWhiteSpace(currentDevice.Location.Building))
                {
                    string b = currentDevice.Location.Building.Trim();
                    string f = currentDevice.Location.Floor?.Trim() ?? "";
                    string r = currentDevice.Location.Room?.Trim() ?? "";
                    string ra = currentDevice.Location.Rack?.Trim() ?? "";

                    var existingLoc = await context.Locations.FirstOrDefaultAsync(l =>
                        (l.Building ?? "") == b && (l.Floor ?? "") == f &&
                        (l.Room ?? "") == r && (l.Rack ?? "") == ra);

                    if (existingLoc != null) currentDevice.LocationId = existingLoc.LocationId;
                    else
                    {
                        var newLoc = new Location { Building = b, Floor = f, Room = r, Rack = ra };
                        context.Locations.Add(newLoc);
                        await context.SaveChangesAsync();
                        currentDevice.LocationId = newLoc.LocationId;
                    }
                }
                else currentDevice.LocationId = null;
            }
            else
            {
                // Là máy ảo thì bắt buộc phải chọn Host và không quan tâm Location/Cắm cáp
                if (currentDevice.ParentDeviceId == null || currentDevice.ParentDeviceId == 0)
                {
                    await JsRuntime.InvokeVoidAsync("alert", "Lỗi: Máy ảo (VM) bắt buộc phải chọn Máy chủ vật lý (Host)!");
                    return;
                }
                currentDevice.LocationId = null;
                currentDevice.UplinkDeviceId = null;
                currentDevice.UplinkPort = null;
            }

            // Ngắt Entity Tracking
            currentDevice.DeviceType = null;
            currentDevice.Location = null;

            if (isNew)
            {
                if (string.IsNullOrEmpty(currentDevice.SerialNumber) && currentDevice.IsVirtual != true)
                    currentDevice.SerialNumber = "SVR-" + DateTime.Now.Ticks.ToString().Substring(10);

                if (string.IsNullOrEmpty(currentDevice.Macaddress))
                    currentDevice.Macaddress = (currentDevice.IsVirtual == true ? "VM-" : "SVR-") + Guid.NewGuid().ToString().Substring(0, 8).ToUpper();

                currentDevice.CreatedDate = DateTime.Now;
                context.Devices.Add(currentDevice);
            }
            else context.Devices.Update(currentDevice);

            await WriteLog(context, isNew ? "ADD_SERVER" : "UPDATE_SERVER", $"{(isNew ? "Thêm" : "Cập nhật")} Server/VM: {currentDevice.DeviceName}");
            await context.SaveChangesAsync();
            showModal = false;
            await LoadData();
            await JsRuntime.InvokeVoidAsync("alert", "Lưu thông tin thành công!");
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("alert", "Lỗi hệ thống: " + (ex.InnerException?.Message ?? ex.Message));
        }
    }

    // CHECK TRẠNG THÁI & HIỆU ỨNG DOMINO (Đã fix lỗi Tracking)
    private async Task CheckStatus(Device d)
    {
        try
        {
            using var context = await DbFactory.CreateDbContextAsync();

            // 1. TÌM TRỰC TIẾP TRONG DB: Lấy dữ liệu mới nhất ra để tránh lỗi xung đột Tracking
            var deviceInDb = await context.Devices.FindAsync(d.DeviceId);
            if (deviceInDb == null) return;

            string newStatus = (deviceInDb.Status == "Online") ? "Offline" : "Online";

            // 2. Ràng buộc: Không bật VM nếu Host đang Offline
            if (newStatus == "Online" && deviceInDb.IsVirtual == true && deviceInDb.ParentDeviceId != null)
            {
                var host = await context.Devices.FindAsync(deviceInDb.ParentDeviceId);
                if (host != null && host.Status == "Offline")
                {
                    await JsRuntime.InvokeVoidAsync("alert", $"⚠ TỪ CHỐI: Không thể bật VM '{deviceInDb.DeviceName}' vì Host '{host.DeviceName}' đang sập!");
                    return;
                }
            }

            // 3. Cập nhật trạng thái (Không cần dùng context.Update nữa vì EF Core tự hiểu)
            deviceInDb.Status = newStatus;
            await WriteLog(context, "POWER_STATE", $"Chuyển trạng thái '{deviceInDb.DeviceName}' thành {newStatus}");

            // 4. Hiệu ứng Domino: Host sập -> VM sập
            if (newStatus == "Offline" && deviceInDb.IsVirtual != true)
            {
                var childVms = await context.Devices.Where(c => c.ParentDeviceId == deviceInDb.DeviceId && c.Status == "Online").ToListAsync();
                if (childVms.Any())
                {
                    foreach (var vm in childVms)
                    {
                        vm.Status = "Offline";
                        // EF Core cũng tự hiểu là đang update các vm này
                        await WriteLog(context, "AUTO_SHUTDOWN", $"Tự động tắt VM '{vm.DeviceName}' do Host bị sập.");
                    }
                    await JsRuntime.InvokeVoidAsync("alert", $"CẢNH BÁO: Đã tắt Server Host. Kéo theo {childVms.Count} máy ảo bên trong sập nguồn theo!");
                }
            }

            await context.SaveChangesAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            await JsRuntime.InvokeVoidAsync("alert", "Lỗi cập nhật nguồn: " + ex.Message);
        }
    }

    private async Task DeleteDevice(Device d)
    {
        using var context = await DbFactory.CreateDbContextAsync();

        // Kiểm tra an toàn: Không cho xóa Host nếu còn VM bên trong
        if (d.IsVirtual != true)
        {
            bool hasVms = await context.Devices.AnyAsync(c => c.ParentDeviceId == d.DeviceId);
            if (hasVms)
            {
                await JsRuntime.InvokeVoidAsync("alert", $"KHÔNG THỂ XÓA: Server '{d.DeviceName}' đang chứa máy ảo. Vui lòng xóa các máy ảo bên trong trước!");
                return;
            }
        }

        bool confirmed = await JsRuntime.InvokeAsync<bool>("confirm", $"Xóa vĩnh viễn {(d.IsVirtual == true ? "máy ảo" : "server")} '{d.DeviceName}'?");
        if (!confirmed) return;

        var logs = await context.ActionLogs.Where(l => l.DeviceId == d.DeviceId).ToListAsync();
        if (logs.Any()) context.ActionLogs.RemoveRange(logs);

        context.Devices.Remove(d);
        await WriteLog(context, "DELETE_SERVER", $"Xóa {(d.IsVirtual == true ? "VM" : "Server")}: {d.DeviceName}");
        await context.SaveChangesAsync();
        await LoadData();
    }

    private async Task WriteLog(WebAppManageContext context, string actionType, string description)
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var username = authState.User.Identity?.Name;
        if (!string.IsNullOrEmpty(username))
        {
            var user = await context.Accounts.FirstOrDefaultAsync(a => a.Username == username);
            if (user != null)
                context.ActionLogs.Add(new ActionLog { AccountId = user.AccountId, ActionType = actionType, Description = description, LogTime = DateTime.Now });
        }
    }

    private void CloseModal() => showModal = false;
}