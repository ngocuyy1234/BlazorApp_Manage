@page "/change-password"
@using BlazorApp_Manage.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject IDbContextFactory<WebAppManageContext> DbFactory
@inject AuthenticationStateProvider AuthStateProvider

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow border-0">
                <div class="card-body p-4">
                    <h3 class="text-center mb-4 fw-bold">🔐 Đổi mật khẩu</h3>
                    
                    @if (!string.IsNullOrEmpty(message))
                    {
                        <div class="alert @(isSuccess ? "alert-success" : "alert-danger") py-2 small">
                            @message
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label">Mật khẩu hiện tại</label>
                        <input type="password" class="form-control" @bind="oldPassword" />
                    </div>
                    <hr />
                    <div class="mb-3">
                        <label class="form-label">Mật khẩu mới</label>
                        <input type="password" class="form-control" @bind="newPassword" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Xác nhận mật khẩu mới</label>
                        <input type="password" class="form-control" @bind="confirmPassword" />
                    </div>

                    <button class="btn btn-primary w-100 py-2 fw-bold" @onclick="HandleChangePassword">
                        Cập nhật mật khẩu
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private string oldPassword = "";
    private string newPassword = "";
    private string confirmPassword = "";
    private string message = "";
    private bool isSuccess = false;

    private async Task HandleChangePassword()
    {
        // 1. Kiểm tra nhập liệu cơ bản
        if (string.IsNullOrEmpty(oldPassword) || string.IsNullOrEmpty(newPassword))
        {
            message = "Vui lòng nhập đầy đủ thông tin.";
            isSuccess = false;
            return;
        }

        if (newPassword != confirmPassword)
        {
            message = "Mật khẩu mới không khớp.";
            isSuccess = false;
            return;
        }

        // 2. Lấy thông tin User hiện tại từ Session
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var username = authState.User.Identity?.Name;

        using var context = await DbFactory.CreateDbContextAsync();
        var user = await context.Accounts.FirstOrDefaultAsync(a => a.Username == username);

        if (user == null || user.PasswordHash != oldPassword)
        {
            message = "Mật khẩu hiện tại không chính xác.";
            isSuccess = false;
            return;
        }

        // 3. Cập nhật mật khẩu mới
        user.PasswordHash = newPassword;
        await context.SaveChangesAsync();

        message = "Đổi mật khẩu thành công!";
        isSuccess = true;
        
        // Reset form
        oldPassword = newPassword = confirmPassword = "";
    }
}