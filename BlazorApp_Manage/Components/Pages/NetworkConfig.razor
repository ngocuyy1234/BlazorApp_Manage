@page "/network-config"
@using BlazorApp_Manage.Data
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization

@attribute [Authorize]
@inject IDbContextFactory<WebAppManageContext> DbFactory
@inject IJSRuntime Js

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold text-primary mb-0"><i class="bi bi-gear-wide-connected"></i> Quản trị Cấu hình Mạng</h3>
            <p class="text-muted small">Quản lý thông số IP, DNS và Trạng thái Cổng vật lý</p>
        </div>
        <button class="btn btn-outline-primary shadow-sm" @onclick="LoadData">
            <i class="bi bi-arrow-clockwise"></i> Làm mới dữ liệu
        </button>
    </div>

    @if (devices == null)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
            <p class="mt-2 text-muted">Đang truy xuất cấu hình hệ thống...</p>
        </div>
    }
    else
    {
        @foreach (var device in devices)
        {
            <div class="card shadow-sm border-0 rounded-4 mb-5">
                <div class="card-header bg-white border-bottom py-3">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h5 class="mb-0 fw-bold text-dark">@device.DeviceName</h5>
                            <small class="text-muted">Device ID: <span class="badge bg-light text-dark border">#@device.DeviceId</span></small>
                        </div>
                        <div class="col-md-6 text-end">
                            <span class="badge @(device.Status == "Online" ? "bg-success" : "bg-danger") rounded-pill px-3">@device.Status</span>
                        </div>
                    </div>
                </div>

                <div class="card-body bg-light">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-uppercase text-muted">Địa chỉ mạng</label>
                            
                            <AuthorizeView Roles="Admin,Technician">
                                <Authorized> @* QUYỀN SỬA *@
                                    <div class="input-group input-group-sm mb-2">
                                        <span class="input-group-text bg-white border-end-0 w-40">IP Address:</span>
                                        <input type="text" class="form-control border-start-0" @bind="device.NetworkConfig.Ipaddress" />
                                    </div>
                                    <div class="input-group input-group-sm">
                                        <span class="input-group-text bg-white border-end-0 w-40">Subnet Mask:</span>
                                        <input type="text" class="form-control border-start-0" @bind="device.NetworkConfig.SubnetMask" />
                                    </div>
                                </Authorized>
                                <NotAuthorized> @* QUYỀN XEM *@
                                    <div class="p-2 border rounded bg-white mb-2 small">IP: <strong>@device.NetworkConfig.Ipaddress</strong></div>
                                    <div class="p-2 border rounded bg-white small">Subnet: <strong>@device.NetworkConfig.SubnetMask</strong></div>
                                </NotAuthorized>
                            </AuthorizeView>
                        </div>

                        <div class="col-md-4">
                            <label class="form-label small fw-bold text-uppercase text-muted">Gateway & DNS</label>
            

                            <AuthorizeView Roles="Admin,Technician">
                                <Authorized>
                                    @* Phần Gateway có thêm nút bấm soi lớp mạng *@
                                    <div class="input-group input-group-sm mb-2 shadow-sm">
                                        <span class="input-group-text bg-white border-end-0" style="width: 100px;">Gateway:</span>
                                        <input type="text" class="form-control border-start-0 border-end-0" @bind="device.NetworkConfig.DefaultGateway" />
                                        <button class="btn btn-outline-primary border-start-0"
                                                title="Xem các lớp mạng con thuộc Gateway này"
                                                @onclick="() => ViewSubnets(device.NetworkConfig.DefaultGateway)">
                                            <i class="bi bi-diagram-3"></i>
                                        </button>
                                    </div>

                                    <div class="input-group input-group-sm mb-2 shadow-sm">
                                        <span class="input-group-text bg-white border-end-0" style="width: 100px;">DNS:</span>
                                        <input type="text" class="form-control border-start-0" @bind="device.NetworkConfig.PrimaryDns" />
                                    </div>
                                </Authorized>
                                <NotAuthorized>
                                    @* Với người xem, biến Gateway thành link nhấn được *@
                                    <div class="p-2 border rounded bg-white mb-2 small d-flex justify-content-between align-items-center">
                                        <span>
                                            GW: <strong class="text-primary" style="cursor:pointer; text-decoration: underline;"
                                                        @onclick="() => ViewSubnets(device.NetworkConfig.DefaultGateway)">
                                                @device.NetworkConfig.DefaultGateway
                                            </strong>
                                        </span>
                                        <i class="bi bi-info-circle text-muted"></i>
                                    </div>
                                    <div class="p-2 border rounded bg-white small">DNS: @device.NetworkConfig.PrimaryDns</div>
                                </NotAuthorized>
                            </AuthorizeView>

                        </div>

                        <div class="col-md-4">
                            
                   
                            <AuthorizeView Roles="Admin,Technician">
                                <div class="mt-3 text-end">
                                    <button class="btn btn-primary px-4 shadow-sm" @onclick="() => SaveNetwork(device)">
                                        <i class="bi bi-save2-fill"></i> Lưu cấu hình
                                    </button>
                                </div>
                            </AuthorizeView>
                        </div>
                    </div>
                </div>

                <div class="card-footer bg-white border-top-0 py-2">
                    <small class="text-muted"><i class="bi bi-clock-history"></i> Cập nhật lần cuối: @(device.NetworkConfig?.UpdatedDate?.ToString("dd/MM/yyyy HH:mm:ss") ?? "Chưa cập nhật")</small>
                </div>
            </div>
        }
    }
</div>

<style>
    .w-40 { width: 100px; justify-content: flex-end; }
    .port-map-container { border: 2px solid #333; min-height: 80px; }
    .mini-port { width: 15px; height: 15px; border-radius: 2px; }
    .mini-port.up { background-color: #28a745; box-shadow: 0 0 5px #28a745; }
    .mini-port.down { background-color: #444; }
</style>

@* MODAL HIỂN THỊ CHI TIẾT SUBNET KHI CLICK VÀO GATEWAY *@
@if (isShowVlanModal)
{
    <div class="modal fade show d-block" style="background: rgba(0,0,0,0.5); backdrop-filter: blur(2px);">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg">
                <div class="modal-header bg-info text-white">
                    <h5 class="modal-title"><i class="bi bi-diagram-3-fill"></i> Thông tin Subnet thuộc Gateway: @currentGateway</h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => isShowVlanModal = false"></button>
                </div>
                <div class="modal-body p-0">
                    @if (subnetList == null || !subnetList.Any())
                    {
                        <div class="p-5 text-center text-muted">
                            <i class="bi bi-exclamation-triangle fs-1"></i>
                            <p>Không tìm thấy Subnet nào khớp với Gateway này trong hệ thống.</p>
                        </div>
                    }
                    else
                    {
                        <table class="table table-hover mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tên VLAN</th>
                                    <th>Địa chỉ mạng</th>
                                    <th>Subnet Mask</th>
                                    <th>Số Host tối đa</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var sub in subnetList)
                                {
                                    <tr>
                                        <td class="fw-bold text-primary">@sub.Vlanname</td>
                                        <td><span class="badge bg-secondary">@sub.NetworkAddress / @sub.Cidr</span></td>
                                        <td>@sub.SubnetMask</td>
                                        <td class="text-success fw-bold">
                                            @(Math.Pow(2, 32 - (sub.Cidr ?? 0)) - 2)
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    }
                </div>
                <div class="modal-footer bg-light">
                    <button class="btn btn-secondary px-4" @onclick="() => isShowVlanModal = false">Đóng</button>
                    @* Nút tắt dẫn sang trang quản lý VLAN *@
                    <a href="/vlans" class="btn btn-primary">
                        <i class="bi bi-gear-fill"></i> Đến trang quản lý Subnet
                    </a>
                </div>
            </div>
        </div>
    </div>
}
@code {
    private List<Device> devices;
    private List<Vlan> subnetList = new();
    private bool isShowVlanModal = false;
    private string currentGateway = "";

    protected override async Task OnInitializedAsync() => await LoadData();

    private async Task LoadData()
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var data = await context.Devices
            .Include(d => d.Ports)
            .Include(d => d.NetworkConfig)
            .ToListAsync();

        foreach (var d in data)
        {
            if (d.NetworkConfig == null)
            {
                d.NetworkConfig = new Data.NetworkConfig
                {
                    DeviceId = d.DeviceId,
                    Ipaddress = "",
                    SubnetMask = "255.255.255.0",
                    DefaultGateway = "",
                    PrimaryDns = "8.8.8.8",
                    SecondaryDns = "8.8.4.4",
                    UpdatedDate = DateTime.Now
                };
            }
        }
        devices = data;
    }

    private async Task SaveNetwork(Device d)
    {
        using var context = await DbFactory.CreateDbContextAsync();
        var isDuplicate = await context.NetworkConfigs
            .AnyAsync(x => x.Ipaddress == d.NetworkConfig.Ipaddress && x.DeviceId != d.DeviceId && !string.IsNullOrEmpty(d.NetworkConfig.Ipaddress));

        if (isDuplicate)
        {
            await Js.InvokeVoidAsync("alert", "Cảnh báo: Địa chỉ IP này đã tồn tại trên thiết bị khác!");
            return;
        }

        d.NetworkConfig.UpdatedDate = DateTime.Now;
        context.NetworkConfigs.Update(d.NetworkConfig);
        await context.SaveChangesAsync();
        await Js.InvokeVoidAsync("alert", "Cấu hình mạng đã được cập nhật thành công!");
    }
    // Hàm thực thi khi người dùng click vào Gateway IP
    private async Task ViewSubnets(string? gatewayIp)
    {
        if (string.IsNullOrWhiteSpace(gatewayIp))
        {
            await Js.InvokeVoidAsync("alert", "Thiết bị này chưa có Gateway để kiểm tra!");
            return;
        }

        currentGateway = gatewayIp.Trim();

        using var context = await DbFactory.CreateDbContextAsync();

        // Lấy danh sách các Subnet (VLAN) có GatewayIP khớp với Gateway của thiết bị
        // Dùng Trim() để tránh lỗi so sánh nếu database có khoảng trắng thừa
        subnetList = await context.Vlans
            .Where(v => v.GatewayIp != null && v.GatewayIp.Trim() == currentGateway)
            .ToListAsync();

        // Mở Modal
        isShowVlanModal = true;

        // Ép Blazor cập nhật lại giao diện ngay lập tức
        StateHasChanged();
    }
}